#!/bin/sh

# ArchCosta BSPWM Configuration
# https://github.com/archcosta/archcosta-bspwm

# -----------------------------------------------------------
# Workspaces
# -----------------------------------------------------------
bspc monitor -d I II III IV V VI VII VIII

# -----------------------------------------------------------
# Global Settings
# -----------------------------------------------------------
bspc config border_width            2
bspc config window_gap              8
bspc config split_ratio             0.52

bspc config focused_border_color    "#00b4d8"
bspc config normal_border_color     "#1a1a2e"
bspc config active_border_color     "#22b8cf"
bspc config presel_feedback_color   "#00b4d8"

bspc config borderless_monocle      true
bspc config gapless_monocle         true
bspc config single_monocle          false
bspc config paddingless_monocle     true

bspc config focus_follows_pointer   true
bspc config pointer_follows_focus   false
bspc config pointer_follows_monitor true

bspc config remove_disabled_monitors  true
bspc config remove_unplugged_monitors true
bspc config merge_overlapping_monitors true

# -----------------------------------------------------------
# Window Rules
# -----------------------------------------------------------
bspc rule -a Firefox            desktop='^2' follow=on
bspc rule -a Chromium           desktop='^2' follow=on
bspc rule -a Thunar             desktop='^3' follow=on
bspc rule -a pcmanfm            desktop='^3' follow=on
bspc rule -a Code               desktop='^4' follow=on
bspc rule -a Gimp               desktop='^5' follow=on state=floating
bspc rule -a Inkscape           desktop='^5' follow=on
bspc rule -a VirtualBox Manager desktop='^6' follow=on
bspc rule -a Spotify            desktop='^7' follow=on
bspc rule -a discord            desktop='^8' follow=on
bspc rule -a Pavucontrol        state=floating
bspc rule -a Lxappearance       state=floating
bspc rule -a Nm-connection-editor state=floating
bspc rule -a Arandr             state=floating
bspc rule -a Galculator         state=floating
bspc rule -a Gpick              state=floating
bspc rule -a Xfce4-power-manager-settings state=floating
bspc rule -a flameshot          state=floating

# -----------------------------------------------------------
# Autostart
# -----------------------------------------------------------

# Kill existing instances before restarting
killall -q sxhkd picom polybar dunst nm-applet

# Wait until the processes have been shut down
while pgrep -x sxhkd > /dev/null; do sleep 0.1; done
while pgrep -x polybar > /dev/null; do sleep 0.1; done

# Hotkey daemon
sxhkd &

# Compositor
picom --config "$HOME/.config/picom/picom.conf" -b

# Polybar
"$HOME/.config/polybar/launch.sh" &

# Wallpaper
feh --bg-fill /usr/share/archcosta/wallpapers/default.png &

# Notification daemon
dunst -config "$HOME/.config/dunst/dunstrc" &

# Network manager applet
nm-applet &

# Polkit authentication agent
/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &

# Cursor
xsetroot -cursor_name left_ptr &

# Keyboard repeat rate
xset r rate 300 50 &

# Screen lock on idle
xset s 300 300 &
xss-lock --transfer-sleep-lock -- i3lock -c 1a1a2e --nofork &

# Load Xresources
[ -f "$HOME/.Xresources" ] && xrdb -merge "$HOME/.Xresources" &
