[org/gnome/desktop/interface]
gtk-theme='adw-gtk3-dark'
icon-theme='Papirus-Dark'
font-name='Noto Sans 11'
document-font-name='Noto Sans 11'
monospace-font-name='JetBrainsMono Nerd Font 10'
color-scheme='prefer-dark'
enable-animations=true
clock-show-weekday=true

[org/gnome/desktop/wm/preferences]
titlebar-font='Noto Sans Bold 11'
button-layout='appmenu:minimize,maximize,close'
focus-mode='click'

[org/gnome/desktop/background]
picture-uri='file:///usr/share/archcosta/wallpapers/default.png'
picture-uri-dark='file:///usr/share/archcosta/wallpapers/default-dark.png'
picture-options='zoom'

[org/gnome/desktop/screensaver]
picture-uri='file:///usr/share/archcosta/wallpapers/default-dark.png'

[org/gnome/desktop/peripherals/touchpad]
tap-to-click=true
natural-scroll=true

[org/gnome/mutter]
center-new-windows=true
dynamic-workspaces=true

[org/gnome/shell]
favorite-apps=['org.gnome.Nautilus.desktop', 'firefox.desktop', 'org.gnome.TextEditor.desktop', 'org.gnome.Terminal.desktop', 'calamares.desktop']

[org/gnome/desktop/input-sources]
sources=[('xkb', 'us')]

[org/gnome/system/location]
enabled=true
