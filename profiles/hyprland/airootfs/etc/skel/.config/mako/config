sort=-time
layer=overlay
anchor=top-right
font=JetBrainsMono Nerd Font 11
width=350
height=120
margin=12
padding=16
border-size=2
border-radius=10
border-color=#00b4d8
background-color=#1a1a2eee
text-color=#e0e0e0
default-timeout=5000
ignore-timeout=0
max-visible=5
icon-path=/usr/share/icons/Papirus-Dark
max-icon-size=48
icons=1

[urgency=low]
border-color=#22b8cf
default-timeout=3000

[urgency=normal]
border-color=#00b4d8
default-timeout=5000

[urgency=critical]
border-color=#e06c75
background-color=#1a1a2eff
text-color=#ffffff
default-timeout=0
