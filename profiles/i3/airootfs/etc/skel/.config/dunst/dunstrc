# ArchCosta Dunst Notification Configuration

[global]
    # Display
    monitor = 0
    follow = mouse
    width = 350
    height = 300
    origin = top-right
    offset = 12x12
    notification_limit = 5

    # Progress bar
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    # Appearance
    transparency = 8
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 12
    frame_width = 2
    frame_color = "#00b4d8"
    separator_color = frame
    corner_radius = 8
    gap_size = 4

    # Text
    font = Noto Sans 10
    line_height = 0
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    word_wrap = yes

    # Icons
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    icon_path = /usr/share/icons/Papirus-Dark/48x48/status/:/usr/share/icons/Papirus-Dark/48x48/devices/

    # Mouse actions
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

    # History
    sticky_history = yes
    history_length = 20

    # Misc
    sort = yes
    idle_threshold = 120
    markup = full
    always_run_script = true
    ignore_dbusclose = false

[urgency_low]
    background = "#1a1a2e"
    foreground = "#e0e0e0"
    frame_color = "#22b8cf"
    timeout = 5
    highlight = "#22b8cf"

[urgency_normal]
    background = "#1a1a2e"
    foreground = "#e0e0e0"
    frame_color = "#00b4d8"
    timeout = 10
    highlight = "#00b4d8"

[urgency_critical]
    background = "#1a1a2e"
    foreground = "#ffffff"
    frame_color = "#e06c75"
    timeout = 0
    highlight = "#e06c75"
