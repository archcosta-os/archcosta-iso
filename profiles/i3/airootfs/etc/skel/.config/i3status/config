# ArchCosta i3status Configuration

general {
    output_format = "i3bar"
    colors = true
    color_good     = "#22b8cf"
    color_degraded = "#e0e0e0"
    color_bad      = "#e06c75"
    interval = 5
    markup = "pango"
}

order += "disk /"
order += "wireless _first_"
order += "ethernet _first_"
order += "battery all"
order += "cpu_usage"
order += "memory"
order += "volume master"
order += "tztime local"

disk "/" {
    format = " %avail"
    low_threshold = 10
    threshold_type = "percentage_avail"
}

wireless _first_ {
    format_up = " %essid %quality"
    format_down = " down"
}

ethernet _first_ {
    format_up = " %ip"
    format_down = " down"
}

battery all {
    format = "%status %percentage %remaining"
    format_down = ""
    status_chr  = ""
    status_bat  = ""
    status_unk  = ""
    status_full = ""
    low_threshold = 20
    threshold_type = "percentage"
    last_full_capacity = true
    integer_battery_capacity = true
}

cpu_usage {
    format = " %usage"
    degraded_threshold = 75
    max_threshold = 90
}

memory {
    format = " %used / %total"
    threshold_degraded = "1G"
    threshold_critical = "512M"
}

volume master {
    format = " %volume"
    format_muted = " muted"
    device = "default"
    mixer = "Master"
    mixer_idx = 0
}

tztime local {
    format = " %a %d %b  %H:%M"
}
